{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"${TMPDIR:-/tmp}/telegram-active.json\" && node \"${CLAUDE_PLUGIN_ROOT}/scripts/telegram-typing-keepalive.cjs\" pre || true",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"$HOME/.claude/channels/telegram/.env\" && node \"${CLAUDE_PLUGIN_ROOT}/scripts/telegram-typing-keepalive.cjs\" || true",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"$HOME/.claude/channels/telegram/.env\" && node \"${CLAUDE_PLUGIN_ROOT}/scripts/telegram-sync-commands.cjs\" || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
