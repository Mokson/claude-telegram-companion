+        let j = i + 1
+        let matched = false
+        while ((j = s.indexOf('_', j)) !== -1) {
+          if (isWordChar(s[j - 1]) && !isWordChar(s[j + 1])) {
+            out += '_' + escapeMdV2Text(s.slice(i + 1, j)) + '_'
+            i = j + 1
+            matched = true
+            break
+          }
+          j++
+        }
+        if (matched) continue
